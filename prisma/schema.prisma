// AWG CRM - Schema do banco de dados
// Fase 1: BID + Clients + Users + System Settings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & PERMISSIONS
// ============================================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  roleId       String   @map("role_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Gmail OAuth — refresh token stored after user authorizes.
  // We exchange it for short-lived access tokens at sync time.
  gmailEmail            String?   @map("gmail_email")
  gmailRefreshToken     String?   @map("gmail_refresh_token")
  gmailConnectedAt      DateTime? @map("gmail_connected_at")
  gmailLastSyncAt       DateTime? @map("gmail_last_sync_at")
  gmailHistoryId        String?   @map("gmail_history_id")

  role              Role                    @relation(fields: [roleId], references: [id])
  modulePermissions UserModulePermission[]
  assignedBids      Bid[]                   @relation("BidAssignedTo")
  statusChanges     BidStatusHistory[]
  extractions       BidExtraction[]         @relation("UserExtractions")

  @@map("users")
}

model Module {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userPermissions UserModulePermission[]

  @@map("modules")
}

model UserModulePermission {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  moduleId  String  @map("module_id")
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canEdit   Boolean @default(false) @map("can_edit")
  canDelete Boolean @default(false) @map("can_delete")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("user_module_permissions")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  type        String?
  address     String?
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contacts ClientContact[]
  bids     Bid[]

  @@map("clients")
}

model ClientContact {
  id        String  @id @default(uuid())
  clientId  String  @map("client_id")
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean @default(false) @map("is_primary")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

// ============================================================
// BIDS
// ============================================================

// Valid status values: new, qualified, rejected, sent_to_takeoff, won, lost
// Valid source values: manual, email_ai, portal_api
model Bid {
  id                    String    @id @default(uuid())
  bidNumber             String    @unique @map("bid_number")
  clientId              String    @map("client_id")
  assignedTo            String?   @map("assigned_to")
  projectName           String    @map("project_name")
  projectAddress        String?   @map("project_address")
  projectLatitude       Decimal?  @map("project_latitude")
  projectLongitude      Decimal?  @map("project_longitude")
  distanceMiles         Decimal?  @map("distance_miles")
  workType              String?   @map("work_type")
  receivedDate          DateTime? @map("received_date")
  responseDeadline      DateTime? @map("response_deadline")
  status                String    @default("new")
  priority              String    @default("medium")
  notes                 String?
  bondRequired          Boolean   @default(false) @map("bond_required")
  unionJob              Boolean   @default(false) @map("union_job")
  prevailingWage        Boolean   @default(false) @map("prevailing_wage")
  davisBacon            Boolean   @default(false) @map("davis_bacon")
  insuranceRequirements String?   @map("insurance_requirements")
  source                String    @default("manual")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  client         Client              @relation(fields: [clientId], references: [id])
  assignedUser   User?               @relation("BidAssignedTo", fields: [assignedTo], references: [id])
  documents      BidDocument[]
  statusHistory  BidStatusHistory[]
  aiAnalysis     BidAiAnalysis[]
  extractions    BidExtraction[]     @relation("BidFromExtraction")
  links          BidLink[]

  @@map("bids")
}

// External URLs found in a bid email — plans on Dropbox/ShareFile,
// BuildingConnected/Procore portal links, walkthrough Zoom links, etc.
// Categories: documents | portal | meeting | addendum | other
model BidLink {
  id        String   @id @default(uuid())
  bidId     String   @map("bid_id")
  url       String
  label     String?
  category  String?
  source    String   @default("email_ai")
  createdAt DateTime @default(now()) @map("created_at")

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@map("bid_links")
}

model BidDocument {
  id              String   @id @default(uuid())
  bidId           String   @map("bid_id")
  fileName        String   @map("file_name")
  fileUrl         String   @map("file_url")
  fileType        String?  @map("file_type")
  documentType    String?  @map("document_type")
  fileSizeKb      Int?     @map("file_size_kb")
  version         Int      @default(1)
  addendumNumber  Int?     @map("addendum_number")
  replacedById    String?  @map("replaced_by_id")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")

  bid        Bid            @relation(fields: [bidId], references: [id], onDelete: Cascade)
  replacedBy BidDocument?   @relation("DocumentVersions", fields: [replacedById], references: [id])
  replaces   BidDocument[]  @relation("DocumentVersions")

  @@map("bid_documents")
}

model BidStatusHistory {
  id         String   @id @default(uuid())
  bidId      String   @map("bid_id")
  changedBy  String   @map("changed_by")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  notes      String?
  changedAt  DateTime @default(now()) @map("changed_at")

  bid  Bid  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  user User @relation(fields: [changedBy], references: [id])

  @@map("bid_status_history")
}

model BidAiAnalysis {
  id                      String   @id @default(uuid())
  bidId                   String   @map("bid_id")
  passesPrequalification  Boolean  @map("passes_prequalification")
  distanceScore           Decimal? @map("distance_score")
  workTypeScore           Decimal? @map("work_type_score")
  overallScore            Decimal? @map("overall_score")
  recommendation          String?
  reasoning               String?
  analyzedAt              DateTime @default(now()) @map("analyzed_at")

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@map("bid_ai_analysis")
}

// ============================================================
// SYSTEM SETTINGS
// ============================================================

// AI extraction of bid emails — auditable record of every Claude call.
// status: pending | accepted | rejected
model BidExtraction {
  id              String    @id @default(uuid())
  bidId           String?   @map("bid_id")
  rawEmail        String    @map("raw_email")
  emailSubject    String?   @map("email_subject")
  fromAddress     String?   @map("from_address")

  extractedData   Json      @map("extracted_data")
  confidence      Decimal?  @db.Decimal(5, 2)
  flags           Json?
  summary         String?

  // Gmail attachments captured at sync time. Each entry:
  //   { messageId, attachmentId, filename, mimeType, sizeBytes }
  // Downloaded + persisted as BidDocument records when the user accepts.
  attachments     Json?     @map("attachments")

  modelUsed       String    @map("model_used")
  inputTokens     Int?      @map("input_tokens")
  outputTokens    Int?      @map("output_tokens")
  cacheReadTokens Int?      @map("cache_read_tokens")
  costCents       Decimal?  @db.Decimal(10, 4) @map("cost_cents")

  status          String    @default("pending")

  extractedBy     String    @map("extracted_by")
  acceptedAt      DateTime? @map("accepted_at")

  createdAt       DateTime  @default(now()) @map("created_at")

  bid             Bid?      @relation("BidFromExtraction", fields: [bidId], references: [id])
  user            User      @relation("UserExtractions", fields: [extractedBy], references: [id])

  @@map("bid_extractions")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
