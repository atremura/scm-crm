// SCM — System Construction Modular
// Multi-tenant: each Company is an isolated tenant.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// COMPANIES (TENANTS)
// ============================================================

model Company {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  website          String?
  logoUrl          String?  @map("logo_url")
  baseAddress      String?  @map("base_address")
  baseLatitude     Decimal? @map("base_latitude")
  baseLongitude    Decimal? @map("base_longitude")
  maxDistanceMiles Int      @default(100) @map("max_distance_miles")
  // Proposal header info (printed on client-facing exports)
  phone            String?
  email            String?
  contactName      String?  @map("contact_name")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  users                   User[]
  clients                 Client[]
  bids                    Bid[]
  settings                SystemSetting[]
  extractions             BidExtraction[]
  bidLinks                BidLink[]
  projects                Project[]
  projectDocuments        ProjectDocument[]
  classificationTemplates ClassificationTemplate[]
  classificationFolders   ClassificationFolder[]
  classifications         Classification[]
  takeoffImports          TakeoffImport[]

  // Estimate module reference catalogs
  divisions           Division[]
  regions             Region[]
  laborTrades         LaborTrade[]
  laborRates          LaborRate[]
  productivityEntries ProductivityEntry[]
  materials           Material[]
  materialTypes       MaterialType[]
  assemblies          Assembly[]
  costFactors         CostFactor[]

  // Estimate operational
  estimates     Estimate[]
  estimateLines EstimateLine[]

  // Derivative cost rules + AI suggestion queue
  derivativeCostRules DerivativeCostRule[]
  suggestions         Suggestion[]

  @@map("companies")
}

// ============================================================
// USERS & PERMISSIONS
// ============================================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  roleId       String   @map("role_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Gmail OAuth — refresh token stored after user authorizes.
  // We exchange it for short-lived access tokens at sync time.
  gmailEmail        String?   @map("gmail_email")
  gmailRefreshToken String?   @map("gmail_refresh_token")
  gmailConnectedAt  DateTime? @map("gmail_connected_at")
  gmailLastSyncAt   DateTime? @map("gmail_last_sync_at")
  gmailHistoryId    String?   @map("gmail_history_id")

  company                  Company                @relation(fields: [companyId], references: [id])
  role                     Role                   @relation(fields: [roleId], references: [id])
  modulePermissions        UserModulePermission[]
  assignedBids             Bid[]                  @relation("BidAssignedTo")
  statusChanges            BidStatusHistory[]
  extractions              BidExtraction[]        @relation("UserExtractions")
  projectsEstimated        Project[]              @relation("ProjectEstimator")
  projectsSentToEstimate   Project[]              @relation("ProjectSentToEstimateBy")
  projectsAsEstimateTarget Project[]              @relation("ProjectEstimateReceiver")
  documentsUploaded        ProjectDocument[]      @relation("ProjectDocUploader")
  takeoffImports           TakeoffImport[]        @relation("TakeoffImporter")
  estimatesOwned           Estimate[]             @relation("EstimateOwner")
  estimatesReceivedFrom    Estimate[]             @relation("EstimateReceivedFrom")

  @@index([companyId])
  @@map("users")
}

model Module {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userPermissions UserModulePermission[]

  @@map("modules")
}

model UserModulePermission {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  moduleId  String  @map("module_id")
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canEdit   Boolean @default(false) @map("can_edit")
  canDelete Boolean @default(false) @map("can_delete")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("user_module_permissions")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  companyName String   @map("company_name")
  type        String?
  address     String?
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company  Company         @relation(fields: [companyId], references: [id])
  contacts ClientContact[]
  bids     Bid[]
  projects Project[]

  @@index([companyId])
  @@map("clients")
}

model ClientContact {
  id        String  @id @default(uuid())
  clientId  String  @map("client_id")
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean @default(false) @map("is_primary")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

// ============================================================
// BIDS
// ============================================================

// Valid status values: new, qualified, rejected, sent_to_takeoff, won, lost
// Valid source values: manual, email_ai, portal_api
model Bid {
  id                    String    @id @default(uuid())
  companyId             String    @map("company_id")
  bidNumber             String    @map("bid_number")
  clientId              String    @map("client_id")
  assignedTo            String?   @map("assigned_to")
  projectName           String    @map("project_name")
  projectAddress        String?   @map("project_address")
  projectLatitude       Decimal?  @map("project_latitude")
  projectLongitude      Decimal?  @map("project_longitude")
  distanceMiles         Decimal?  @map("distance_miles")
  workType              String?   @map("work_type")
  receivedDate          DateTime? @map("received_date")
  responseDeadline      DateTime? @map("response_deadline")
  status                String    @default("new")
  priority              String    @default("medium")
  notes                 String?
  bondRequired          Boolean   @default(false) @map("bond_required")
  unionJob              Boolean   @default(false) @map("union_job")
  prevailingWage        Boolean   @default(false) @map("prevailing_wage")
  davisBacon            Boolean   @default(false) @map("davis_bacon")
  insuranceRequirements String?   @map("insurance_requirements")
  source                String    @default("manual")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  company       Company            @relation(fields: [companyId], references: [id])
  client        Client             @relation(fields: [clientId], references: [id])
  assignedUser  User?              @relation("BidAssignedTo", fields: [assignedTo], references: [id])
  documents     BidDocument[]
  statusHistory BidStatusHistory[]
  aiAnalysis    BidAiAnalysis[]
  extractions   BidExtraction[]    @relation("BidFromExtraction")
  links         BidLink[]
  projects      Project[]

  @@unique([companyId, bidNumber])
  @@index([companyId])
  @@map("bids")
}

// External URLs found in a bid email — plans on Dropbox/ShareFile,
// BuildingConnected/Procore portal links, walkthrough Zoom links, etc.
// Categories: documents | portal | meeting | addendum | other
model BidLink {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  bidId     String   @map("bid_id")
  url       String
  label     String?
  category  String?
  source    String   @default("email_ai")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("bid_links")
}

model BidDocument {
  id             String   @id @default(uuid())
  bidId          String   @map("bid_id")
  fileName       String   @map("file_name")
  fileUrl        String   @map("file_url")
  fileType       String?  @map("file_type")
  documentType   String?  @map("document_type")
  fileSizeKb     Int?     @map("file_size_kb")
  version        Int      @default(1)
  addendumNumber Int?     @map("addendum_number")
  replacedById   String?  @map("replaced_by_id")
  uploadedAt     DateTime @default(now()) @map("uploaded_at")

  bid        Bid           @relation(fields: [bidId], references: [id], onDelete: Cascade)
  replacedBy BidDocument?  @relation("DocumentVersions", fields: [replacedById], references: [id])
  replaces   BidDocument[] @relation("DocumentVersions")

  @@map("bid_documents")
}

model BidStatusHistory {
  id         String   @id @default(uuid())
  bidId      String   @map("bid_id")
  changedBy  String   @map("changed_by")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  notes      String?
  changedAt  DateTime @default(now()) @map("changed_at")

  bid  Bid  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  user User @relation(fields: [changedBy], references: [id])

  @@map("bid_status_history")
}

model BidAiAnalysis {
  id                     String   @id @default(uuid())
  bidId                  String   @map("bid_id")
  passesPrequalification Boolean  @map("passes_prequalification")
  distanceScore          Decimal? @map("distance_score")
  workTypeScore          Decimal? @map("work_type_score")
  overallScore           Decimal? @map("overall_score")
  recommendation         String?
  reasoning              String?
  analyzedAt             DateTime @default(now()) @map("analyzed_at")

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@map("bid_ai_analysis")
}

// ============================================================
// SYSTEM SETTINGS
// ============================================================

// AI extraction of bid emails — auditable record of every Claude call.
// status: pending | accepted | rejected
model BidExtraction {
  id           String  @id @default(uuid())
  companyId    String  @map("company_id")
  bidId        String? @map("bid_id")
  rawEmail     String  @map("raw_email")
  emailSubject String? @map("email_subject")
  fromAddress  String? @map("from_address")

  extractedData Json     @map("extracted_data")
  confidence    Decimal? @db.Decimal(5, 2)
  flags         Json?
  summary       String?

  // Gmail attachments captured at sync time. Each entry:
  //   { messageId, attachmentId, filename, mimeType, sizeBytes }
  // Downloaded + persisted as BidDocument records when the user accepts.
  attachments Json? @map("attachments")

  modelUsed       String   @map("model_used")
  inputTokens     Int?     @map("input_tokens")
  outputTokens    Int?     @map("output_tokens")
  cacheReadTokens Int?     @map("cache_read_tokens")
  costCents       Decimal? @map("cost_cents") @db.Decimal(10, 4)

  status String @default("pending")

  extractedBy String    @map("extracted_by")
  acceptedAt  DateTime? @map("accepted_at")

  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  bid     Bid?    @relation("BidFromExtraction", fields: [bidId], references: [id])
  user    User    @relation("UserExtractions", fields: [extractedBy], references: [id])

  @@index([companyId])
  @@map("bid_extractions")
}

model SystemSetting {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  key         String
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
  @@index([companyId])
  @@map("system_settings")
}

// ============================================================
// TAKEOFF — Projects, documents, classifications, imports
// ============================================================

// A Project groups all takeoff work for a single construction job.
// It may be spun up from a qualified Bid (bidId set) or created
// standalone (bidId null) when the job didn't come through the bid funnel.
// status values: active | archived | sent_to_estimate | estimate_accepted
model Project {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  bidId         String?   @map("bid_id")
  clientId      String?   @map("client_id")
  estimatorId   String?   @map("estimator_id")
  name          String
  projectNumber String?   @map("project_number")
  address       String?
  workType      String?   @map("work_type")
  status        String    @default("active")
  notes         String?
  startedAt     DateTime  @default(now()) @map("started_at")
  archivedAt    DateTime? @map("archived_at")

  // Handoff to the Estimate/Proposal module. Filled by "Send to Estimate".
  // estimateReceiverId can equal estimatorId when one person does both
  // jobs; will point at a different user once the team grows and proposal
  // lives in a dedicated role.
  sentToEstimateAt    DateTime? @map("sent_to_estimate_at")
  sentToEstimateById  String?   @map("sent_to_estimate_by_id")
  estimateReceiverId  String?   @map("estimate_receiver_id")
  estimateAcceptedAt  DateTime? @map("estimate_accepted_at")
  estimateHandoffNote String?   @map("estimate_handoff_note")

  // Project context hints — JSONB blob containing stories, durationWeeks,
  // siteConditions, requiredEquipment, winterRisk, permitChecklist and any
  // future fields. Populated by IA-1 (via Suggestion approval) or by the
  // Cowork importer (Phase 2). See src/lib/project-context-hints.ts for
  // the type contract.
  contextHints Json? @map("context_hints")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company          Company           @relation(fields: [companyId], references: [id])
  bid              Bid?              @relation(fields: [bidId], references: [id])
  client           Client?           @relation(fields: [clientId], references: [id])
  estimator        User?             @relation("ProjectEstimator", fields: [estimatorId], references: [id])
  sentToEstimateBy User?             @relation("ProjectSentToEstimateBy", fields: [sentToEstimateById], references: [id])
  estimateReceiver User?             @relation("ProjectEstimateReceiver", fields: [estimateReceiverId], references: [id])
  documents        ProjectDocument[]
  classifications  Classification[]
  imports          TakeoffImport[]
  estimate         Estimate?

  @@index([companyId])
  @@index([bidId])
  @@map("projects")
}

// Any file attached to a Project — plans, specs, addenda, site photos, etc.
// documentType values: plans | specs | addendum | photo | other
model ProjectDocument {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  projectId    String   @map("project_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileType     String?  @map("file_type")
  fileSizeKb   Int?     @map("file_size_kb")
  documentType String   @map("document_type")
  note         String?
  uploadedBy   String   @map("uploaded_by")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  company  Company @relation(fields: [companyId], references: [id])
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation("ProjectDocUploader", fields: [uploadedBy], references: [id])

  @@index([companyId])
  @@index([projectId])
  @@map("project_documents")
}

// Folder tree for organizing classification templates in the library.
// type is implicitly per-tenant via companyId.
model ClassificationFolder {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  parentId  String?  @map("parent_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  company   Company                  @relation(fields: [companyId], references: [id])
  parent    ClassificationFolder?    @relation("ClassificationFolderTree", fields: [parentId], references: [id])
  children  ClassificationFolder[]   @relation("ClassificationFolderTree")
  templates ClassificationTemplate[]

  @@index([companyId])
  @@index([parentId])
  @@map("classification_folders")
}

// Per-tenant library of reusable classification definitions.
// type values: area | linear | count
// defaultUom values: SF | LF | EA (extendable)
// defaultScope values: service | service_and_material — tells the Estimate
// module's AI whether to price labor only or labor + materials for items
// imported from this template.
model ClassificationTemplate {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  folderId     String?  @map("folder_id")
  name         String
  externalId   String?  @map("external_id")
  type         String
  defaultUom   String   @map("default_uom")
  defaultScope String   @default("service_and_material") @map("default_scope")
  defaultColor String?  @map("default_color")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company               @relation(fields: [companyId], references: [id])
  folder    ClassificationFolder? @relation(fields: [folderId], references: [id])
  instances Classification[]

  @@index([companyId])
  @@index([folderId])
  @@map("classification_templates")
}

// Instance of a classification on a specific Project. Carries the quantity,
// UOM, and optional unit cost used for rollup + export to Estimate later.
// type values: area | linear | count
// uom values: SF | LF | EA
// scope values: service | service_and_material — tells the Estimate module
// whether it should price labor only or labor + materials for this item.
model Classification {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  projectId  String   @map("project_id")
  templateId String?  @map("template_id")
  name       String
  externalId String?  @map("external_id")
  type       String
  uom        String
  scope      String   @default("service_and_material")
  quantity   Decimal  @default(0) @db.Decimal(14, 3)
  unitCost   Decimal? @map("unit_cost") @db.Decimal(12, 2)
  color      String?
  note       String?

  // Togal-native fields — captured at import time. Used by the Estimate
  // module's classification resolver to do deterministic L1/L2 matching
  // (matchCode prefix → ProductivityEntry) BEFORE falling back to AI.
  // togalId       = the "ID (Optional)" field from Togal's Create Area dialog
  // togalFolder   = the "Folder (Optional)" — usually a Division name
  // togalLabelOriginal = full label as exported (Togal UI truncates @ ~12 chars,
  //                      but the .xlsx carries the full string)
  togalId            String? @map("togal_id")
  togalFolder        String? @map("togal_folder")
  togalLabelOriginal String? @map("togal_label_original")

  // Structured FK — set when the resolver classifies (or user picks manually).
  // Lets the AI pre-filter the catalog by division before any fuzzy text.
  divisionId String? @map("division_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company       Company                 @relation(fields: [companyId], references: [id])
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template      ClassificationTemplate? @relation(fields: [templateId], references: [id])
  division      Division?               @relation(fields: [divisionId], references: [id])
  estimateLines EstimateLine[]

  @@index([companyId])
  @@index([projectId])
  @@index([divisionId])
  @@map("classifications")
}

// Audit trail of every external import that wrote quantities into a Project.
// source values: togal | manual | csv
model TakeoffImport {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  projectId    String   @map("project_id")
  source       String
  fileName     String?  @map("file_name")
  rowsImported Int      @map("rows_imported")
  rowsCreated  Int      @map("rows_created")
  rowsUpdated  Int      @map("rows_updated")
  importedBy   String   @map("imported_by")
  importedAt   DateTime @default(now()) @map("imported_at")

  company Company @relation(fields: [companyId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("TakeoffImporter", fields: [importedBy], references: [id])

  @@index([companyId])
  @@index([projectId])
  @@map("takeoff_imports")
}

// ============================================================
// ESTIMATE / PROPOSAL — Reference catalogs (per-tenant)
// ============================================================
// Populated initially from AWG's productivity spreadsheet
// (AWG_Construction_Productivity_Database_V2.xlsx). The Estimate
// and EstimateLine tables that consume these come in a later
// migration once the proposal-build UI lands.

// Top-level trade division: Rough Carpentry, Siding, Drywall, etc.
model Division {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String
  code         String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id])
  trades              LaborTrade[]
  productivityRows    ProductivityEntry[]
  materials           Material[]
  assemblies          Assembly[]
  classifications     Classification[]
  derivativeCostRules DerivativeCostRule[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("divisions")
}

// A geographic market where the company operates. Labor rates and
// certain cost factors are scoped to a region.
model Region {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String
  stateCode String   @map("state_code")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company      @relation(fields: [companyId], references: [id])
  laborRates  LaborRate[]
  costFactors CostFactor[]
  estimates   Estimate[]

  @@unique([companyId, stateCode])
  @@index([companyId])
  @@map("regions")
}

// A skilled labor category (Carpenter Rough/Finish, Tile Setter,
// Painter, ...). Rate varies by region and shop type — see LaborRate.
model LaborTrade {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  name       String
  divisionId String?  @map("division_id")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id])
  division           Division?           @relation(fields: [divisionId], references: [id])
  rates              LaborRate[]
  productivityRows   ProductivityEntry[]
  assemblyComponents AssemblyComponent[]
  estimateLines      EstimateLine[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([divisionId])
  @@map("labor_trades")
}

// Hourly rate for a trade in a region. shopType distinguishes
// open-shop from union work. Low/Avg/High supports conservative-vs-
// aggressive estimate toggling.
// shopType values: "open_shop" | "union"
model LaborRate {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  tradeId   String   @map("trade_id")
  regionId  String   @map("region_id")
  shopType  String   @map("shop_type")
  lowCents  Int?     @map("low_cents")
  avgCents  Int      @map("avg_cents")
  highCents Int?     @map("high_cents")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company    @relation(fields: [companyId], references: [id])
  trade   LaborTrade @relation(fields: [tradeId], references: [id])
  region  Region     @relation(fields: [regionId], references: [id])

  @@unique([companyId, tradeId, regionId, shopType])
  @@index([companyId])
  @@map("labor_rates")
}

// Man-hours per unit to perform a defined scope of work. The auto-
// pricing engine matches a Takeoff classification (by matchCode or
// fuzzy matchKeywords) and multiplies by quantity to get labor hours.
model ProductivityEntry {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  divisionId      String   @map("division_id")
  scopeName       String   @map("scope_name")
  uom             String
  crewDescription String?  @map("crew_description")
  assumedTradeId  String?  @map("assumed_trade_id")
  mhPerUnitLow    Decimal? @map("mh_per_unit_low") @db.Decimal(10, 4)
  mhPerUnitAvg    Decimal  @map("mh_per_unit_avg") @db.Decimal(10, 4)
  mhPerUnitHigh   Decimal? @map("mh_per_unit_high") @db.Decimal(10, 4)
  matchCode       String?  @map("match_code")
  matchKeywords   String?  @map("match_keywords")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id])
  division           Division            @relation(fields: [divisionId], references: [id])
  assumedTrade       LaborTrade?         @relation(fields: [assumedTradeId], references: [id])
  assemblyComponents AssemblyComponent[]
  estimateLines      EstimateLine[]

  @@index([companyId])
  @@index([divisionId])
  @@index([matchCode])
  @@map("productivity_entries")
}

// Optional hierarchical material category (Fiber Cement Siding,
// Lumber, Hardware, ...). `slug` is a stable key used by the
// catalog importer to upsert types across re-runs; `name` is the
// human label.
model MaterialType {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  slug      String?
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  company   Company        @relation(fields: [companyId], references: [id])
  parent    MaterialType?  @relation("MaterialTypeTree", fields: [parentId], references: [id])
  children  MaterialType[] @relation("MaterialTypeTree")
  materials Material[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([parentId])
  @@map("material_types")
}

// A single catalog item. lastPricedAt surfaces stale entries in the
// UI. wastePercent is baked in, but an EstimateLine can override it.
model Material {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  divisionId     String?   @map("division_id")
  materialTypeId String?   @map("material_type_id")
  name           String
  sku            String?
  uom            String
  lowCents       Int?      @map("low_cents")
  avgCents       Int       @map("avg_cents")
  highCents      Int?      @map("high_cents")
  wastePercent   Int       @default(5) @map("waste_percent")
  supplier       String?
  supplierUrl    String?   @map("supplier_url")
  lastPricedAt   DateTime? @map("last_priced_at")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id])
  division           Division?           @relation(fields: [divisionId], references: [id])
  materialType       MaterialType?       @relation(fields: [materialTypeId], references: [id])
  assemblyComponents AssemblyComponent[]

  @@index([companyId])
  @@index([divisionId])
  @@index([materialTypeId])
  @@map("materials")
}

// Reusable recipe combining labor + material components into one
// estimate line (e.g. "Exterior Wall 2x6 + Hardie"). Not part of
// the initial auto-pricing path — used once a tenant has stable
// repeatable scopes.
model Assembly {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  divisionId   String?  @map("division_id")
  code         String?
  name         String
  uom          String
  defaultScope String   @default("service_and_material") @map("default_scope")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company    Company             @relation(fields: [companyId], references: [id])
  division   Division?           @relation(fields: [divisionId], references: [id])
  components AssemblyComponent[]

  @@index([companyId])
  @@index([divisionId])
  @@index([code])
  @@map("assemblies")
}

// One piece of an assembly. Can reference catalog rows
// (productivity + material) OR carry inline labor/material values.
model AssemblyComponent {
  id                   String   @id @default(uuid())
  assemblyId           String   @map("assembly_id")
  componentName        String   @map("component_name")
  qtyPerUnit           Decimal  @map("qty_per_unit") @db.Decimal(12, 4)
  componentUom         String   @map("component_uom")
  productivityId       String?  @map("productivity_id")
  laborTradeId         String?  @map("labor_trade_id")
  materialId           String?  @map("material_id")
  mhPerComponent       Decimal? @map("mh_per_component") @db.Decimal(10, 4)
  materialCostCents    Int?     @map("material_cost_cents")
  wastePercentOverride Int?     @map("waste_percent_override")
  displayOrder         Int      @default(0) @map("display_order")
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at")

  assembly     Assembly           @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  productivity ProductivityEntry? @relation(fields: [productivityId], references: [id])
  laborTrade   LaborTrade?        @relation(fields: [laborTradeId], references: [id])
  material     Material?          @relation(fields: [materialId], references: [id])

  @@index([assemblyId])
  @@map("assembly_components")
}

// Multiplier applied at estimate time to a subset of costs
// (labor / material / overhead). "Boston Metro +15%", "Prevailing
// Wage +35%", "HVHZ +18%", "Winter +8%".
//
// autoApply = true: the factor is pre-checked on a new estimate
// when its conditions match (e.g. regionId equals the estimate's
// region). The user can still uncheck it. False factors are
// opt-in only.
//
// appliesTo values: "labor" | "material" | "overhead"
model CostFactor {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  regionId      String?  @map("region_id")
  name          String
  impactPercent Decimal  @map("impact_percent") @db.Decimal(5, 3)
  appliesTo     String   @map("applies_to")
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  autoApply     Boolean  @default(false) @map("auto_apply")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company              Company              @relation(fields: [companyId], references: [id])
  region               Region?              @relation(fields: [regionId], references: [id])
  estimateApplications EstimateCostFactor[]

  @@index([companyId])
  @@index([regionId])
  @@map("cost_factors")
}

// ============================================================
// ESTIMATE / PROPOSAL — Operational tables
// ============================================================

// One Estimate per Project (enforced by @unique on projectId).
// Revisions to a sent proposal are captured via status transitions
// + EstimateCostFactor snapshots; a new "proposal variant" feature
// can later be modeled as multiple Estimates per Project if needed.
//
// status flow:
//   draft ──(owner runs pricing)──▶ in_pricing
//   in_pricing ──(owner locks)──▶ pricing_done
//   pricing_done ──(owner submits)──▶ submitted_to_client
//   submitted_to_client ──▶ won | lost | cancelled
//   * ──(owner cancels)──▶ cancelled
model Estimate {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  projectId String @unique @map("project_id")
  status    String @default("draft")

  // Handoff metadata — who owns the proposal + who sent it from Takeoff
  ownerId        String    @map("owner_id")
  receivedFromId String?   @map("received_from_id")
  receivedAt     DateTime? @map("received_at")
  acceptedAt     DateTime? @map("accepted_at")

  // Configuration driving auto-pricing
  regionId    String @map("region_id")
  shopType    String @default("open_shop") @map("shop_type")
  mhRangeMode String @default("avg") @map("mh_range_mode") // "low" | "avg" | "high"

  // Margins (defaults come from SystemSetting on create; user overrides here).
  // All three are applied to Direct Cost (labor + material) in FLAT mode —
  // matches how AWG's real proposals stack: GC + Overhead + Profit all
  // percent-of-direct, summed alongside direct for the grand total. Not
  // cascaded on top of each other.
  // - generalConditionsPercent: staging, scaffolding, lift, small tools
  // - overheadPercent:          company overhead (insurance, office, GC)
  // - markupPercent:            profit (labeled "Profit" in the UI)
  // - salesTaxPercent:          optional; applied to final total
  markupPercent            Decimal? @map("markup_percent") @db.Decimal(5, 2)
  overheadPercent          Decimal? @map("overhead_percent") @db.Decimal(5, 2)
  generalConditionsPercent Decimal? @map("general_conditions_percent") @db.Decimal(5, 2)
  contingencyPercent       Decimal? @map("contingency_percent") @db.Decimal(5, 2)
  salesTaxPercent          Decimal? @map("sales_tax_percent") @db.Decimal(5, 2)

  // Project envelope area for "cost per SF" metric. Optional — blank means
  // we skip the metric.
  totalEnvelopeSf Decimal? @map("total_envelope_sf") @db.Decimal(14, 2)

  // Free-form bullets the estimator wants printed on the proposal
  // (e.g. "Scaffolding/staging included", "Painting excluded"). Rendered
  // as a Notes & Assumptions section on the PDF/export.
  assumptions String?

  // IA-2 Hidden Cost Detector — last run timestamp + raw payload for audit.
  // Derivative lines are persisted as EstimateLine rows with source='ai-derivative';
  // this column captures the AI's reasoning + costs even after lines are pruned.
  aiHiddenCostsRunAt  DateTime? @map("ai_hidden_costs_run_at") @db.Timestamptz(6)
  aiHiddenCostsResult Json?     @map("ai_hidden_costs_result")

  // Proposal output
  proposalNumber String?   @map("proposal_number")
  clientName     String?   @map("client_name") // snapshot from Project.Client
  validForDays   Int       @default(30) @map("valid_for_days")
  submittedAt    DateTime? @map("submitted_at")
  wonAt          DateTime? @map("won_at")
  lostAt         DateTime? @map("lost_at")
  lostReason     String?   @map("lost_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company        Company              @relation(fields: [companyId], references: [id])
  project        Project              @relation(fields: [projectId], references: [id])
  region         Region               @relation(fields: [regionId], references: [id])
  owner          User                 @relation("EstimateOwner", fields: [ownerId], references: [id])
  receivedFrom   User?                @relation("EstimateReceivedFrom", fields: [receivedFromId], references: [id])
  lines          EstimateLine[]
  appliedFactors EstimateCostFactor[]

  @@index([companyId])
  @@index([status])
  @@map("estimates")
}

// One line per Takeoff Classification (seeded at Accept time) or
// ad-hoc line (classificationId null). Everything on this row is
// a snapshot — editing a LaborRate or ProductivityEntry later
// never retroactively changes priced estimates.
model EstimateLine {
  id               String  @id @default(uuid())
  companyId        String  @map("company_id")
  estimateId       String  @map("estimate_id")
  classificationId String? @map("classification_id")

  // Descriptive snapshot (even if the source Classification gets renamed)
  name       String
  externalId String? @map("external_id")
  scope      String // service | service_and_material
  uom        String
  quantity   Decimal @db.Decimal(14, 3)

  // Resolved refs + snapshotted values
  productivityEntryId String?  @map("productivity_entry_id")
  laborTradeId        String?  @map("labor_trade_id")
  mhPerUnit           Decimal? @map("mh_per_unit") @db.Decimal(10, 4)
  laborHours          Decimal? @map("labor_hours") @db.Decimal(12, 3)
  laborRateCents      Int?     @map("labor_rate_cents")
  laborCostCents      Int?     @map("labor_cost_cents")

  // Material cost breakdown lives in JSON — one line can expand to
  // multiple materials (e.g. Hardie siding = panel + trim + nails).
  // Structure: [{ name, qty, uom, unitCostCents, wastePercent, materialId? }]
  materialCostCents    Int?  @map("material_cost_cents")
  materialBreakdown    Json? @map("material_breakdown")
  wastePercentOverride Int?  @map("waste_percent_override")

  // Sale price after markup (computed at save time)
  unitPriceCents Int? @map("unit_price_cents")
  subtotalCents  Int? @map("subtotal_cents")

  // Organization / display
  displayOrder Int     @default(0) @map("display_order")
  groupName    String? @map("group_name")

  // AI / confidence tracking
  suggestedByAi  Boolean @default(false) @map("suggested_by_ai")
  aiConfidence   Int?    @map("ai_confidence") // 0-100
  userOverridden Boolean @default(false) @map("user_overridden")
  needsReview    Boolean @default(false) @map("needs_review")
  notes          String?

  // Provenance — how this line came to exist:
  //   togal-id       — matched via Togal "ID" field exact (highest confidence)
  //   togal-prefix   — matched via Name prefix regex (e.g. ELFCS-1 → ELFCS)
  //   ai-classified  — fell through to AI classifier
  //   ai-derivative  — generated by IA-2 Hidden Cost Detector (fasteners, etc)
  //   manual         — added by hand in the UI
  source            String?
  // Derivative lines are children of a "main" line. Lets the rollup show
  // them grouped under the parent and lets the user delete the parent +
  // all its derivatives in one shot.
  parentLineId      String? @map("parent_line_id")
  // FK to the rule that generated a derivative line. Null for non-derivative.
  derivedFromRuleId String? @map("derived_from_rule_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company           Company             @relation(fields: [companyId], references: [id])
  estimate          Estimate            @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  classification    Classification?     @relation(fields: [classificationId], references: [id])
  productivityEntry ProductivityEntry?  @relation(fields: [productivityEntryId], references: [id])
  laborTrade        LaborTrade?         @relation(fields: [laborTradeId], references: [id])
  parentLine        EstimateLine?       @relation("EstimateLineDerivatives", fields: [parentLineId], references: [id], onDelete: Cascade)
  derivatives       EstimateLine[]      @relation("EstimateLineDerivatives")
  derivedFromRule   DerivativeCostRule? @relation(fields: [derivedFromRuleId], references: [id])

  @@index([companyId])
  @@index([estimateId])
  @@index([classificationId])
  @@index([parentLineId])
  @@map("estimate_lines")
}

// Each cost factor the user opted in on an estimate. Snapshot of
// name + impact + appliesTo so future edits to the underlying
// CostFactor don't silently re-price closed estimates.
// autoApplied=true means this was pre-checked by the system on
// create (region match) rather than manually added by the user.
model EstimateCostFactor {
  id           String  @id @default(uuid())
  estimateId   String  @map("estimate_id")
  costFactorId String? @map("cost_factor_id")

  // Snapshot
  name          String
  impactPercent Decimal @map("impact_percent") @db.Decimal(5, 3)
  appliesTo     String  @map("applies_to") // labor | material | overhead
  autoApplied   Boolean @default(false) @map("auto_applied")

  createdAt DateTime @default(now()) @map("created_at")

  estimate   Estimate    @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  costFactor CostFactor? @relation(fields: [costFactorId], references: [id])

  @@index([estimateId])
  @@map("estimate_cost_factors")
}

// ============================================================
// DERIVATIVE COSTS & AI SUGGESTIONS
// ============================================================

// Per-tenant rules that generate "implicit" cost lines from explicit ones.
// E.g. "Hardie smooth siding (matchCode ELFCS) → 0.025 box of ring-shank
// nails per SF". When IA-2 runs, it iterates the estimate's lines, looks
// up rules whose trigger matches, and inserts EstimateLine rows with
// source='ai-derivative' + derivedFromRuleId pointing here.
//
// Hybrid origin:
//   - createdBy='manual' → Andre or Cowork seeded the rule
//   - createdBy='ai-suggested-approved' → IA-2 proposed it via Suggestion,
//     Andre approved, the system materialized the rule
//
// costType values: material | labor | site | cleanup
// formula JSON shape (discriminated by .kind):
//   { kind: 'qty_per_unit',     factor: 0.025, materialId, uomIn:'SF', uomOut:'BX' }
//   { kind: 'percent_of_direct', percent: 2.5,  costType:'material' }
//   { kind: 'fixed_per_week',    cents: 65000,  weeksFromProject: true }
//   { kind: 'count_per_opening', perUnit: 2,    triggerExternalIdPattern:'^A\\d' }
model DerivativeCostRule {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // Trigger — at least one must be set. matchCode is preferred (more precise);
  // divisionId is the broader catch-all.
  triggerProductivityMatchCode String? @map("trigger_productivity_match_code")
  triggerDivisionId            String? @map("trigger_division_id")

  name          String
  costType      String  @map("cost_type")
  formula       Json
  materialIdRef String? @map("material_id_ref")
  uomIn         String? @map("uom_in")
  uomOut        String? @map("uom_out")
  isActive      Boolean @default(true) @map("is_active")
  createdBy     String  @default("manual") @map("created_by")
  notes         String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company       Company        @relation(fields: [companyId], references: [id])
  division      Division?      @relation(fields: [triggerDivisionId], references: [id])
  estimateLines EstimateLine[]

  @@index([companyId])
  @@index([triggerProductivityMatchCode])
  @@index([triggerDivisionId])
  @@map("derivative_cost_rules")
}

// Generic "AI proposes, Andre approves" queue.
//
// Principle: IA never writes to master tables (Material, LaborRate,
// ProductivityEntry, DerivativeCostRule) directly. When IA detects
// something missing or wrong, it creates a Suggestion. Andre reviews
// in admin UI, approves → system applies → suggestion is archived.
//
// type values:
//   productivity            — propose a new ProductivityEntry
//   material                — propose a new Material
//   derivative_rule         — propose a new DerivativeCostRule (IA-2)
//   productivity_rate_change — propose adjusting MH/unit (feedback loop)
//   equipment_rule          — propose a new EquipmentRule (IA-4 future)
//
// status values: pending | approved | rejected | archived
model Suggestion {
  id            String @id @default(uuid())
  companyId     String @map("company_id")
  type          String
  payload       Json // proposal data (shape depends on type)
  justification String // why AI suggested
  confidence    Int    @default(50) // 0-100

  // Provenance — what triggered the suggestion
  sourceEstimateId String?  @map("source_estimate_id")
  sourceLineId     String?  @map("source_line_id")
  modelUsed        String?  @map("model_used")
  costCents        Decimal? @map("cost_cents") @db.Decimal(10, 4)

  // Review state
  status         String    @default("pending")
  reviewedById   String?   @map("reviewed_by_id")
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewNote     String?   @map("review_note")
  appliedToTable String?   @map("applied_to_table") // 'productivity_entries' | 'materials' | 'derivative_cost_rules'
  appliedToId    String?   @map("applied_to_id") // FK in that table once approved

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
  @@index([type, status])
  @@map("suggestions")
}

